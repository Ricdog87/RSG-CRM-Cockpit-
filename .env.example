# Supabase – nur ANON-Key, niemals der Service-Role-Key im Frontend.
# Diese Werte trägst du in Vercel (Project Settings → Environment Variables) ein.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: erzwingt den Mock-Datenmodus auch wenn Supabase-ENV gesetzt sind.
# NEXT_PUBLIC_COCKPIT_USE_MOCK=true

# ── KI / Lead Intelligence (alle serverseitig, nie NEXT_PUBLIC) ──────────
# Standard-Brain: Claude über das Anthropic-SDK (smartestes Modell).
ANTHROPIC_API_KEY=sk-ant-...
# Optional: anderes Modell (Default: claude-opus-4-8)
# AI_MODEL=claude-opus-4-8

# Optional: Web-gestützte B2B-Recherche für Leads.
# PERPLEXITY_API_KEY=pplx-...

# Optional: Alternativer LLM-Provider statt Anthropic.
# Wenn nur dieser gesetzt ist, wird über OpenRouter geroutet
# (Default-Modell dann: anthropic/claude-opus-4-8).
# OPENROUTER_API_KEY=sk-or-...
